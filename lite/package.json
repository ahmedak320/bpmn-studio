{
  "name": "orbitpm-process-studio-lite",
  "version": "0.3.0",
  "description": "OrbitPM Process Studio Lite — a zero-install, single-file BPMN editor that runs entirely in the browser. Reuses the desktop app's generation pipeline; AI via CORS-capable providers (Anthropic, Gemini).",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.18",
    "@ai-sdk/google": "^4.0.21",
    "@bpmn-io/properties-panel": "^3.47.0",
    "ai": "^7.0.34",
    "bpmn-auto-layout": "0.4.0",
    "bpmn-js": "^18.21.0",
    "bpmn-js-create-append-anything": "^1.3.1",
    "bpmn-js-properties-panel": "^5.61.0",
    "bpmn-moddle": "^9.0.4",
    "diagram-js-minimap": "^5.4.0",
    "fflate": "^0.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.3",
    "vite": "^5.4.21",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^2.1.8"
  }
