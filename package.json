{
  "name": "orbitpm-process-studio",
  "version": "0.0.1",
  "description": "OrbitPM Process Studio — draw, organize, and link BPMN 2.0 diagrams; generate diagrams from text with AI when online.",
  "main": "./out/main/index.js",
  "author": "ahmedak320",
  "homepage": "https://github.com/ahmedak320/bpmn-studio",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "postinstall": "electron-builder install-app-deps",
    "dist:win": "npm run build && electron-builder --win",
    "smoke": "electron ./out/main/index.js --smoke-test"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
