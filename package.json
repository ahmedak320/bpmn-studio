{
  "name": "orbitpm-process-studio",
  "version": "0.0.1-alpha.2",
  "description": "OrbitPM Process Studio — draw, organize, and link BPMN 2.0 diagrams; generate diagrams from text with AI when online.",
  "main": "./out/main/index.js",
  "author": "ahmedak320",
  "homepage": "https://github.com/ahmedak320/bpmn-studio",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "postinstall": "electron-builder install-app-deps",
    "dist:win": "npm run build && electron-builder --win",
    "smoke": "electron ./out/main/index.js --smoke-test"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.18",
    "@ai-sdk/azure": "^4.0.18",
    "@ai-sdk/deepseek": "^3.0.13",
    "@ai-sdk/google": "^4.0.21",
    "@ai-sdk/openai": "^4.0.17",
    "@ai-sdk/openai-compatible": "^3.0.14",
    "@bpmn-io/properties-panel": "^3.47.0",
    "ai": "^7.0.34",
    "bpmn-auto-layout": "0.4.0",
    "bpmn-js": "^18.21.0",
    "bpmn-js-create-append-anything": "^1.3.1",
    "bpmn-js-properties-panel": "^5.61.0",
    "chokidar": "^5.0.0",
    "diagram-js-minimap": "^5.4.0",
    "electron-updater": "^6.3.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
